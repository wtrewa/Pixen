# ─── Application ────────────────────────────────────────────────
APP_PORT=3000
APP_ENV=development
APP_NAME=pixen-backend
FRONTEND_URL=https://pixxen.in

# ─── Database ────────────────────────────────────────────────────
# Prefer DATABASE_URL on Railway/cloud. Falls back to individual vars locally.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_NAME=pixen_db
DB_SYNC=false
DB_LOGGING=false

# ─── Redis ───────────────────────────────────────────────────────
# Prefer REDIS_URL on Railway/cloud. Falls back to individual vars locally.
REDIS_URL=redis://:password@host:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_TTL=300

# ─── JWT ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── OAuth (Google) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.pixxen.in/api/v1/auth/google/callback

# ─── AWS S3 ──────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=pixen-media

# ─── SMTP Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pixen.in

# ─── Payment ─────────────────────────────────────────────────────
PAYMENT_GATEWAY=CASHFREE

# Cashfree
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_ENV=sandbox

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Rate Limiting ───────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
